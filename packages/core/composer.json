{
  "name": "dayone/core",
  "description": "DayOne: multi-product SaaS runtime for Laravel",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12.0",
    "laravel/cashier": "^16.0",
    "laravel/sanctum": "^4.3",
    "filament/filament": "^5.0",
    "dedoc/scramble": "^0.13"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "pestphp/pest": "^4.0",
    "phpunit/phpunit": "^12.0",
    "phpstan/phpstan": "^2.0",
    "larastan/larastan": "^3.0",
    "laravel/pint": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "DayOne\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DayOne\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "DayOne\\DayOneServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
